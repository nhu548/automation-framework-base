<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Parabank Regression Suite"
       verbose="1">

    <test name="UI Regression">

        <classes>

            <class name="ui.tests.LoginTest"/>

            <class name="ui.tests.AccountsOverviewTest"/>

            <class name="ui.tests.AccountDetailsTest"/>

            <class name="ui.tests.EndToEndBankingTest"/>

            <class name="ui.tests.TransferFundsTest">
                <methods>
                    <exclude name="verifyTransferRejectedWhenAmountIsZero"/>
                    <exclude name="verifyTransferRejectedDueToInsufficientBalance"/>
                </methods>
            </class>

        </classes>

    </test>

</suite>