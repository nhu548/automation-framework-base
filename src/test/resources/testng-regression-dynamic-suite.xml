<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Bank Regression Suite">

    <test name="Setup Test Data">
        <classes>
            <class name="setup.UserSetupTest"/>
        </classes>
    </test>

    <test name="API Tests">
        <classes>
            <class name="api.tests.LoginApiTest"/>
            <class name="api.tests.CustomerApiTest"/>
            <class name="api.tests.AccountApiTest"/>
            <class name="api.tests.TransferApiTest"/>
        </classes>
    </test>

    <test name="UI Tests">
        <classes>
            <class name="ui.tests.LoginTest"/>
            <class name="ui.tests.AccountsOverviewTest"/>
            <class name="ui.tests.AccountDetailsTest"/>
            <class name="ui.tests.OpenNewAccountTest"/>
            <class name="ui.tests.TransferFundsTest"/>
            <class name="ui.tests.EndToEndBankingTest"/>
        </classes>
    </test>

    <test name="Hybrid Tests">
        <classes>
            <class name="hybrid.tests.HybridBankingE2ETest"/>
        </classes>
    </test>

</suite>